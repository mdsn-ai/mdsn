{
  "name": "@mdsnai/sdk",
  "version": "0.3.4",
  "private": false,
  "description": "Reference SDK for building MDSN apps with Markdown-first pages, actions, and browser runtimes.",
  "license": "MIT",
  "homepage": "https://docs.mdsn.ai",
  "bugs": {
    "url": "https://github.com/mdsn-ai/mdsn/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mdsn-ai/mdsn.git"
  },
  "keywords": [
    "mdsn",
    "markdown",
    "sdk",
    "ai",
    "agent",
    "agentic",
    "workflow",
    "interactive-documents",
    "skills-app",
    "agent-app",
    "server",
    "web-components"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./dist/web/index.js"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "default": "./dist/elements/index.js"
    }
  },
  "dependencies": {
    "lit": "^3.3.1"
  }
}
