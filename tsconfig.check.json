{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "vitest/globals",
      "react"
    ]
  },
  "include": [
    "sdk/src/**/*.ts",
    "tests/**/*.ts",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "docs/server/**/*.ts"
  ]
}
